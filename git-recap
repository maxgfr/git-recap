#!/usr/bin/env bash
set -euo pipefail

# ==============================================================================
# git-recap — Monthly commit recap CLI
# ==============================================================================

VERSION="1.5.0"
CONFIG_FILE="$HOME/.git-recaprc"

# Defaults
DEFAULT_PERIOD="current-month"
DEFAULT_MODE="all"
DEFAULT_FORMAT="text"
DEFAULT_PROVIDER="claude"
DEFAULT_LANG="en"
DEFAULT_VOICE="I"

# State
ARG_USER=""
ARG_PERIOD=""
ARG_MODE=""
ARG_FORMAT=""
ARG_OUTPUT=""
ARG_BRANCH=""
ARG_PROVIDER=""
ARG_MODEL=""
ARG_LANG=""
ARG_VOICE=""
ARG_REPO=""
ARG_INIT=false
ARG_TEAM=false
ARG_ALL_BRANCHES=false
NO_AI=false

# Resolved values
USER_NAME=""
REPO_FULL=""
REPO_NAME=""
REPO_MODE=""  # local or remote
BRANCH=""
SINCE=""
UNTIL=""
PERIOD_LABEL=""
PROVIDER=""
MODEL=""
LANG_CODE=""
VOICE_MODE=""
SPINNER_PID=""
AI_SUMMARY=""
AI_BULLETS=""

# ==============================================================================
# Helpers
# ==============================================================================

_color() { if [[ -t 2 ]]; then printf '\033[%sm' "$1" >&2; fi; }
_reset() { if [[ -t 2 ]]; then printf '\033[0m' >&2; fi; }

info()  { _color "34"; printf ":: %s\n" "$*" >&2; _reset; }
warn()  { _color "33"; printf "!! %s\n" "$*" >&2; _reset; }
error() { _color "31"; printf "!! %s\n" "$*" >&2; _reset; }
die()   { error "$@"; exit 1; }

spinner_start() {
    local msg="$1"
    if [[ -t 2 ]]; then
        (
            local chars='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
            local i=0
            while true; do
                printf '\r\033[34m%s %s\033[0m' "${chars:i%${#chars}:1}" "$msg" >&2
                i=$((i + 1))
                sleep 0.1
            done
        ) &
        SPINNER_PID=$!
    fi
}

spinner_stop() {
    if [[ -n "${SPINNER_PID:-}" ]]; then
        kill "$SPINNER_PID" 2>/dev/null || true
        wait "$SPINNER_PID" 2>/dev/null || true
        printf '\r\033[K' >&2
        SPINNER_PID=""
    fi
}

cleanup() {
    spinner_stop
}
trap cleanup EXIT INT TERM HUP

# --- Portable date ---

_GNU_DATE=""
_is_gnu_date() {
    if [[ -z "$_GNU_DATE" ]]; then
        if date --version >/dev/null 2>&1; then
            _GNU_DATE=1
        else
            _GNU_DATE=0
        fi
    fi
    [[ "$_GNU_DATE" -eq 1 ]]
}

# portable_date <operation> [args...]
#   first_of_month <offset>       - First day of month, offset months from now
#   first_of_next_month           - First day of next month
#   month_label <offset>          - Human month label, offset months from now
#   month_label_from <YYYY-MM-DD> - Human month label from specific date
portable_date() {
    local op="$1"; shift
    case "$op" in
        first_of_month)
            local offset="${1:-0}"
            if _is_gnu_date; then
                if [[ "$offset" -eq 0 ]]; then
                    date -d "$(date +%Y-%m-01)" +%Y-%m-%dT00:00:00
                elif [[ "$offset" -lt 0 ]]; then
                    local abs=$(( -offset ))
                    date -d "$(date +%Y-%m-01) -${abs} month" +%Y-%m-%dT00:00:00
                else
                    date -d "$(date +%Y-%m-01) +${offset} month" +%Y-%m-%dT00:00:00
                fi
            else
                if [[ "$offset" -eq 0 ]]; then
                    LC_ALL=C date -v1d -v0H -v0M -v0S +%Y-%m-%dT%H:%M:%S
                elif [[ "$offset" -lt 0 ]]; then
                    LC_ALL=C date -v1d -v"${offset}"m -v0H -v0M -v0S +%Y-%m-%dT%H:%M:%S
                else
                    LC_ALL=C date -v1d -v+"${offset}"m -v0H -v0M -v0S +%Y-%m-%dT%H:%M:%S
                fi
            fi
            ;;
        first_of_next_month)
            if _is_gnu_date; then
                date -d "$(date +%Y-%m-01) +1 month" +%Y-%m-%dT00:00:00
            else
                LC_ALL=C date -v1d -v+1m -v0H -v0M -v0S +%Y-%m-%dT%H:%M:%S
            fi
            ;;
        month_label)
            local offset="${1:-0}"
            if _is_gnu_date; then
                if [[ "$offset" -eq 0 ]]; then
                    LC_ALL=C date +"%B %Y"
                elif [[ "$offset" -lt 0 ]]; then
                    local abs=$(( -offset ))
                    LC_ALL=C date -d "-${abs} month" +"%B %Y"
                else
                    LC_ALL=C date -d "+${offset} month" +"%B %Y"
                fi
            else
                if [[ "$offset" -eq 0 ]]; then
                    LC_ALL=C date +"%B %Y"
                else
                    LC_ALL=C date -v"${offset}"m +"%B %Y"
                fi
            fi
            ;;
        month_label_from)
            local from_date="$1"
            if _is_gnu_date; then
                LC_ALL=C date -d "$from_date" +"%B %Y"
            else
                LC_ALL=C date -jf '%Y-%m-%d' "$from_date" +"%B %Y" 2>/dev/null || echo "${from_date:0:7}"
            fi
            ;;
    esac
}

# --- AI helpers ---

_strip_bullet_markers() {
    sed -E 's/^[[:space:]]*([-*+]|[0-9]+[.)]) //' | grep -v '^[[:space:]]*$' || true
}

_truncate_messages() {
    local max="${1:-200}"
    local lines
    lines=$(cat)
    local count
    count=$(echo "$lines" | wc -l | tr -d ' ')
    if [[ $count -gt $max ]]; then
        warn "Truncating to $max commit messages for AI"
        echo "$lines" | head -"$max"
    else
        echo "$lines"
    fi
}

_json_escape() {
    if command -v jq &>/dev/null; then
        jq -Rs .
    elif command -v python3 &>/dev/null; then
        python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'
    else
        die "jq or python3 required for AI API calls"
    fi
}

_lang_name() {
    case "${1:-en}" in
        en) echo "English" ;;
        fr) echo "French" ;;
        es) echo "Spanish" ;;
        de) echo "German" ;;
        it) echo "Italian" ;;
        pt) echo "Portuguese" ;;
        ja) echo "Japanese" ;;
        zh) echo "Chinese" ;;
        ko) echo "Korean" ;;
        ar) echo "Arabic" ;;
        ru) echo "Russian" ;;
        nl) echo "Dutch" ;;
        *) echo "$1" ;;
    esac
}

_voice_instruction() {
    case "${1:-I}" in
        I|i|je)   echo "Write from a first-person singular perspective, using 'I'. Present the work as your own accomplishments." ;;
        we|We|nous) echo "Write from a first-person plural perspective, using 'we'. Present the work as team accomplishments." ;;
        neutral) echo "Use a noun-based impersonal style. Each item should start with an action noun (e.g., 'Implementation of the home page', 'Optimization of build times', 'Setup of CI/CD pipeline'). Never use first-person pronouns (I, we). Keep it professional and concise." ;;
        nominal|neutre) echo "Use a French-style noun-based impersonal style (style nominal). Each item should start with an action noun (e.g., 'Mise en place de la page d'accueil', 'Optimisation des temps de build', 'Intégration des retours designer', 'Déploiement de la nouvelle version'). Never use first-person pronouns (je, nous, j'ai). Keep it professional, concise and suitable for a project status report." ;;
    esac
}

