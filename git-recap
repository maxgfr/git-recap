#!/usr/bin/env bash
set -euo pipefail

# ==============================================================================
# git-recap — Monthly commit recap CLI
# ==============================================================================

VERSION="1.0.0"
CONFIG_FILE="$HOME/.git-recaprc"

# Defaults
DEFAULT_PERIOD="current"
DEFAULT_MODE="all"
DEFAULT_FORMAT="text"
DEFAULT_PROVIDER="claude"

# State
ARG_USER=""
ARG_PERIOD=""
ARG_MODE=""
ARG_FORMAT=""
ARG_OUTPUT=""
ARG_BRANCH=""
ARG_PROVIDER=""
ARG_REPO=""
ARG_INIT=false

# Resolved values
USER_NAME=""
REPO_FULL=""
REPO_NAME=""
REPO_MODE=""  # local or remote
BRANCH=""
SINCE=""
UNTIL=""
PERIOD_LABEL=""
PROVIDER=""
SPINNER_PID=""

# ==============================================================================
# Helpers
# ==============================================================================

_color() { [[ -t 2 ]] && printf '\033[%sm' "$1" >&2 || true; }
_reset() { [[ -t 2 ]] && printf '\033[0m' >&2 || true; }

info()  { _color "34"; printf ":: %s\n" "$*" >&2; _reset; }
warn()  { _color "33"; printf "!! %s\n" "$*" >&2; _reset; }
error() { _color "31"; printf "!! %s\n" "$*" >&2; _reset; }
die()   { error "$@"; exit 1; }

spinner_start() {
    local msg="$1"
    if [[ -t 2 ]]; then
        (
            local chars='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
            local i=0
            while true; do
                printf '\r\033[34m%s %s\033[0m' "${chars:i%${#chars}:1}" "$msg" >&2
                i=$((i + 1))
                sleep 0.1
            done
        ) &
        SPINNER_PID=$!
    fi
}

spinner_stop() {
    if [[ -n "${SPINNER_PID:-}" ]]; then
        kill "$SPINNER_PID" 2>/dev/null || true
        wait "$SPINNER_PID" 2>/dev/null || true
        printf '\r\033[K' >&2
        SPINNER_PID=""
    fi
}

cleanup() {
    spinner_stop
}
trap cleanup EXIT

# ==============================================================================
# Help
# ==============================================================================

show_help() {
    cat <<'HELP'
git-recap — Monthly commit recap generator

Usage:
  git-recap [OPTIONS] <repo>

Arguments:
  <repo>              GitHub URL, owner/repo, repo name, or local path (.)

Options:
  -u, --user <user>       GitHub username (auto-detected via gh)
  -p, --period <period>   Period: current, last, <N>, YYYY-MM (default: current)
  -m, --mode <mode>       Mode: summary, commits, bullets, all (default: all)
  -f, --format <format>   Format: text, markdown (default: text)
  -o, --output <file>     Write output to file
  -b, --branch <branch>   Branch (default: auto-detected)
  --provider <provider>   AI provider: claude, openai (default: claude)
  --init                  Initialize configuration
  -h, --help              Show this help
  -v, --version           Show version

Examples:
  git-recap maxgfr/subtool
  git-recap -p last -f markdown -o recap.md maxgfr/subtool
  git-recap -p 2026-01 -m commits maxgfr/subtool
  git-recap https://github.com/maxgfr/subtool
  git-recap .
HELP
}

# ==============================================================================
# Argument parsing
# ==============================================================================

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -u|--user)    ARG_USER="${2:?Missing value for $1}"; shift 2 ;;
            -p|--period)  ARG_PERIOD="${2:?Missing value for $1}"; shift 2 ;;
            -m|--mode)    ARG_MODE="${2:?Missing value for $1}"; shift 2 ;;
            -f|--format)  ARG_FORMAT="${2:?Missing value for $1}"; shift 2 ;;
            -o|--output)  ARG_OUTPUT="${2:?Missing value for $1}"; shift 2 ;;
            -b|--branch)  ARG_BRANCH="${2:?Missing value for $1}"; shift 2 ;;
            --provider)   ARG_PROVIDER="${2:?Missing value for $1}"; shift 2 ;;
            --init)       ARG_INIT=true; shift ;;
            -h|--help)    show_help; exit 0 ;;
            -v|--version) echo "git-recap $VERSION"; exit 0 ;;
            -*)           die "Unknown option: $1" ;;
            *)
                [[ -z "$ARG_REPO" ]] || die "Unexpected argument: $1"
                ARG_REPO="$1"; shift ;;
        esac
    done
}

validate_args() {
    local mode="${ARG_MODE:-$DEFAULT_MODE}"
    local format="${ARG_FORMAT:-$DEFAULT_FORMAT}"
    local provider="${ARG_PROVIDER:-$DEFAULT_PROVIDER}"

    case "$mode" in
        summary|commits|bullets|all) ;;
        *) die "Invalid mode: $mode (expected: summary, commits, bullets, all)" ;;
    esac

    case "$format" in
        text|markdown) ;;
        *) die "Invalid format: $format (expected: text, markdown)" ;;
    esac

    case "$provider" in
        claude|openai) ;;
        *) die "Invalid provider: $provider (expected: claude, openai)" ;;
    esac

    if [[ "$ARG_INIT" == false && -z "$ARG_REPO" ]]; then
        die "Missing required argument: <repo>. Use -h for help."
    fi
}

# ==============================================================================
# Configuration
# ==============================================================================

config_load() {
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck disable=SC1090
        source "$CONFIG_FILE"
    fi
}

detect_github_user() {
    if command -v gh &>/dev/null; then
        if ! gh auth status &>/dev/null; then
            return
        fi
        gh api user --jq '.login' 2>/dev/null || true
    fi
}

config_init() {
    info "Initializing git-recap configuration..."

    local detected_user
    detected_user=$(detect_github_user)

    local user=""
    if [[ -n "$detected_user" ]]; then
        printf "GitHub username [%s]: " "$detected_user" >&2
        read -r user
        [[ -z "$user" ]] && user="$detected_user"
    else
        printf "GitHub username: " >&2
        read -r user
        [[ -z "$user" ]] && die "Username is required"
    fi

    local provider=""
    printf "AI provider (claude/openai) [claude]: " >&2
    read -r provider
    [[ -z "$provider" ]] && provider="claude"

    local default_format=""
    printf "Default format (text/markdown) [text]: " >&2
    read -r default_format
    [[ -z "$default_format" ]] && default_format="text"

    cat > "$CONFIG_FILE" <<EOF
# git-recap configuration
GIT_RECAP_USER="$user"
GIT_RECAP_PROVIDER="$provider"
GIT_RECAP_FORMAT="$default_format"
EOF

    info "Configuration saved to $CONFIG_FILE"
}

# ==============================================================================
# Period computation
# ==============================================================================

compute_period() {
    local period="${ARG_PERIOD:-$DEFAULT_PERIOD}"

    case "$period" in
        current|"")
            SINCE=$(LC_ALL=C date -v1d -v0H -v0M -v0S +%Y-%m-%dT%H:%M:%S)
            UNTIL=$(LC_ALL=C date -v1d -v+1m -v0H -v0M -v0S +%Y-%m-%dT%H:%M:%S)
            PERIOD_LABEL=$(LC_ALL=C date +"%B %Y")
            ;;
        last)
            SINCE=$(LC_ALL=C date -v1d -v-1m -v0H -v0M -v0S +%Y-%m-%dT%H:%M:%S)
            UNTIL=$(LC_ALL=C date -v1d -v0H -v0M -v0S +%Y-%m-%dT%H:%M:%S)
            PERIOD_LABEL=$(LC_ALL=C date -v-1m +"%B %Y")
            ;;
        [0-9]|[0-9][0-9])
            local n="$period"
            SINCE=$(LC_ALL=C date -v1d -v-"${n}"m -v0H -v0M -v0S +%Y-%m-%dT%H:%M:%S)
            UNTIL=$(LC_ALL=C date -v1d -v+1m -v0H -v0M -v0S +%Y-%m-%dT%H:%M:%S)
            local start_label end_label
            start_label=$(LC_ALL=C date -v-"${n}"m +"%B %Y")
            end_label=$(LC_ALL=C date +"%B %Y")
            PERIOD_LABEL="${start_label} - ${end_label}"
            ;;
        [0-9][0-9][0-9][0-9]-[0-9][0-9])
            local year="${period%%-*}"
            local month="${period##*-}"
            # Build SINCE from the given YYYY-MM
            SINCE="${year}-${month}-01T00:00:00"
            # Compute UNTIL (first day of next month)
            local next_month=$((10#$month + 1))
            local next_year="$year"
            if [[ $next_month -gt 12 ]]; then
                next_month=1
                next_year=$((year + 1))
            fi
            UNTIL=$(printf '%s-%02d-01T00:00:00' "$next_year" "$next_month")
            PERIOD_LABEL=$(LC_ALL=C date -jf '%Y-%m-%d' "${year}-${month}-01" +"%B %Y" 2>/dev/null || echo "$period")
            ;;
        *)
            die "Invalid period: $period (expected: current, last, <N>, YYYY-MM)"
            ;;
    esac

    info "Period: $PERIOD_LABEL ($SINCE → $UNTIL)"
}

# ==============================================================================
# Repo resolution
# ==============================================================================

resolve_repo() {
    local repo="$ARG_REPO"

    # Local path
    if [[ "$repo" == "." || "$repo" == "./" || -d "$repo/.git" ]]; then
        REPO_MODE="local"
        local dir
        if [[ "$repo" == "." || "$repo" == "./" ]]; then
            dir="$(pwd)"
        else
            dir="$(cd "$repo" && pwd)"
        fi
        # Extract owner/repo from remote origin
        local remote_url
        remote_url=$(git -C "$dir" remote get-url origin 2>/dev/null) || die "No remote 'origin' found in $dir"
        # Strip to owner/repo
        REPO_FULL=$(echo "$remote_url" | sed -E 's#^(https://github\.com/|git@github\.com:)##; s/\.git$//')
        REPO_NAME="${REPO_FULL##*/}"
        info "Local repo: $REPO_FULL"
        return
    fi

    REPO_MODE="remote"

    # GitHub URL
    if [[ "$repo" == https://github.com/* ]]; then
        REPO_FULL=$(echo "$repo" | sed -E 's#^https://github\.com/##; s/\.git$//; s#/$##')
        REPO_NAME="${REPO_FULL##*/}"
        info "Repo: $REPO_FULL"
        return
    fi

    # owner/repo
    if [[ "$repo" == */* ]]; then
        REPO_FULL="$repo"
        REPO_NAME="${REPO_FULL##*/}"
        info "Repo: $REPO_FULL"
        return
    fi

    # repo name only — prefix with username
    REPO_FULL="${USER_NAME}/${repo}"
    REPO_NAME="$repo"
    info "Repo: $REPO_FULL (using user: $USER_NAME)"
}

detect_default_branch() {
    if [[ -n "$ARG_BRANCH" ]]; then
        BRANCH="$ARG_BRANCH"
        return
    fi

    if [[ "$REPO_MODE" == "local" ]]; then
        BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's#refs/remotes/origin/##' || echo "main")
    else
        BRANCH=$(gh api "repos/${REPO_FULL}" --jq '.default_branch' 2>/dev/null || echo "main")
    fi

    info "Branch: $BRANCH"
}

# ==============================================================================
# Dependencies
# ==============================================================================

check_gh_auth() {
    if command -v gh &>/dev/null; then
        if ! gh auth status &>/dev/null; then
            die "gh is not authenticated. Run: gh auth login"
        fi
    fi
}

check_dependencies() {
    command -v git &>/dev/null || die "git is required but not found"

    if [[ "${REPO_MODE:-remote}" == "remote" ]]; then
        if ! command -v gh &>/dev/null && ! command -v curl &>/dev/null; then
            die "gh or curl is required for remote repos"
        fi
        check_gh_auth
    fi

    local mode="${ARG_MODE:-$DEFAULT_MODE}"
    if [[ "$mode" == "summary" || "$mode" == "bullets" || "$mode" == "all" ]]; then
        local provider="${PROVIDER:-$DEFAULT_PROVIDER}"
        if [[ "$provider" == "claude" ]] && ! command -v claude &>/dev/null; then
            warn "claude CLI not found — AI summary will be skipped"
        fi
        if [[ "$provider" == "openai" ]] && [[ -z "${OPENAI_API_KEY:-}" ]]; then
            warn "OPENAI_API_KEY not set — AI summary will be skipped"
        fi
    fi
}

# ==============================================================================
# Fetch commits
# ==============================================================================

fetch_commits() {
    local commits=""

    if [[ "$REPO_MODE" == "local" ]]; then
        info "Fetching commits (local)..."
        local dir="$ARG_REPO"
        [[ "$dir" == "." || "$dir" == "./" ]] && dir="$(pwd)"
        commits=$(git -C "$dir" log "$BRANCH" \
            --author="$USER_NAME" \
            --since="$SINCE" --until="$UNTIL" \
            --format='%h%x09%s%x09%as' --no-merges 2>/dev/null || true)
    elif command -v gh &>/dev/null; then
        info "Fetching commits (gh api)..."
        local api_url="repos/${REPO_FULL}/commits?sha=${BRANCH}&author=${USER_NAME}&since=${SINCE}Z&until=${UNTIL}Z&per_page=100"
        local api_err=""
        commits=$(gh api "$api_url" --paginate \
            --jq '.[] | [.sha[0:7], (.commit.message | split("\n")[0]), (.commit.author.date | split("T")[0])] | @tsv' 2>&1) || api_err="$commits"
        if [[ -n "$api_err" ]]; then
            case "$api_err" in
                *"404"*) die "Repository not found: ${REPO_FULL}" ;;
                *"403"*) die "Access denied (rate limit or permissions): ${REPO_FULL}" ;;
                *) die "API error: ${api_err}" ;;
            esac
        fi
    elif command -v curl &>/dev/null; then
        info "Fetching commits (curl)..."
        local url="https://api.github.com/repos/${REPO_FULL}/commits?sha=${BRANCH}&author=${USER_NAME}&since=${SINCE}Z&until=${UNTIL}Z&per_page=100"
        local json
        json=$(curl -s "$url")
        if command -v jq &>/dev/null; then
            commits=$(echo "$json" | jq -r '.[] | [.sha[0:7], (.commit.message | split("\n")[0]), (.commit.author.date | split("T")[0])] | @tsv' 2>/dev/null || true)
        else
            die "jq is required when using curl fallback"
        fi
    else
        die "No method available to fetch commits"
    fi

    if [[ -z "$commits" ]]; then
        warn "No commits found for $USER_NAME on $REPO_FULL ($PERIOD_LABEL)"
        echo ""
        return
    fi

    local count
    count=$(echo "$commits" | wc -l | tr -d ' ')
    info "Found $count commit(s)"

    echo "$commits"
}

# ==============================================================================
# AI Summary
# ==============================================================================

generate_summary() {
    local commits="$1"
    local mode="${ARG_MODE:-$DEFAULT_MODE}"

    # Only generate if mode requires it
    if [[ "$mode" != "summary" && "$mode" != "all" ]]; then
        return
    fi

    if [[ -z "$commits" ]]; then
        return
    fi

    local messages
    messages=$(echo "$commits" | cut -f2)

    # Truncate if too many commits
    local msg_count
    msg_count=$(echo "$messages" | wc -l | tr -d ' ')
    if [[ $msg_count -gt 200 ]]; then
        warn "Truncating to 200 commits for AI summary"
        messages=$(echo "$messages" | head -200)
    fi

    local prompt
    prompt="You are writing a professional monthly work recap. Below are git commit messages from a developer for ${PERIOD_LABEL} on the repository ${REPO_NAME}.

Write a concise summary (3-5 sentences) suitable for a monthly report. Synthesize by themes (features, bug fixes, refactoring, documentation, etc.). Use a professional tone. Do not list individual commits — provide a high-level overview of what was accomplished.

Commit messages:
${messages}"

    local summary=""

    if [[ "$PROVIDER" == "claude" ]]; then
        if command -v claude &>/dev/null; then
            spinner_start "Generating AI summary..."
            summary=$(unset CLAUDECODE; printf '%s' "$prompt" | claude -p --model sonnet 2>/dev/null) || true
            spinner_stop
        else
            warn "claude CLI not found — skipping AI summary"
        fi
    elif [[ "$PROVIDER" == "openai" ]]; then
        if [[ -n "${OPENAI_API_KEY:-}" ]]; then
            spinner_start "Generating AI summary..."
            local escaped_prompt
            escaped_prompt=$(printf '%s' "$prompt" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')
            local response
            response=$(curl -s https://api.openai.com/v1/chat/completions \
                -H "Content-Type: application/json" \
                -H "Authorization: Bearer $OPENAI_API_KEY" \
                -d "{\"model\":\"gpt-4o-mini\",\"messages\":[{\"role\":\"user\",\"content\":${escaped_prompt}}],\"temperature\":0.7}") || true
            spinner_stop
            if command -v jq &>/dev/null; then
                summary=$(echo "$response" | jq -r '.choices[0].message.content // empty' 2>/dev/null || true)
            fi
        else
            warn "OPENAI_API_KEY not set — skipping AI summary"
        fi
    fi

    if [[ -n "$summary" ]]; then
        echo "$summary"
    else
        warn "AI summary generation failed — skipping"
    fi
}

# ==============================================================================
# Generate bullet points (AI)
# ==============================================================================

generate_ai_bullets() {
    local commits="$1"
    local mode="${ARG_MODE:-$DEFAULT_MODE}"

    # Only generate if mode requires it
    if [[ "$mode" != "bullets" && "$mode" != "all" ]]; then
        return
    fi

    [[ -z "$commits" ]] && return

    local messages
    messages=$(echo "$commits" | cut -f2)

    local prompt
    prompt="You are writing bullet points for a monthly work recap. Below are git commit messages from a developer for ${PERIOD_LABEL} on the repository ${REPO_NAME}.

Transform these commit messages into clean, readable bullet points for a report:
- Group related changes by theme
- Deduplicate similar entries
- Rephrase in clear, professional language
- Remove conventional commit prefixes (feat:, fix:, chore:, etc.)
- Output one bullet point per line, without any bullet marker (no -, *, etc.)
- Do not include any headers or categories — just the items

Commit messages:
${messages}"

    local bullets=""

    if [[ "$PROVIDER" == "claude" ]]; then
        if command -v claude &>/dev/null; then
            spinner_start "Generating AI bullet points..."
            bullets=$(unset CLAUDECODE; printf '%s' "$prompt" | claude -p --model sonnet 2>/dev/null) || true
            spinner_stop
        fi
    elif [[ "$PROVIDER" == "openai" ]]; then
        if [[ -n "${OPENAI_API_KEY:-}" ]]; then
            spinner_start "Generating AI bullet points..."
            local escaped_prompt
            escaped_prompt=$(printf '%s' "$prompt" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')
            local response
            response=$(curl -s https://api.openai.com/v1/chat/completions \
                -H "Content-Type: application/json" \
                -H "Authorization: Bearer $OPENAI_API_KEY" \
                -d "{\"model\":\"gpt-4o-mini\",\"messages\":[{\"role\":\"user\",\"content\":${escaped_prompt}}],\"temperature\":0.7}") || true
            spinner_stop
            if command -v jq &>/dev/null; then
                bullets=$(echo "$response" | jq -r '.choices[0].message.content // empty' 2>/dev/null || true)
            fi
        fi
    fi

    if [[ -n "$bullets" ]]; then
        echo "$bullets"
    else
        # Fallback: raw commit messages
        echo "$messages"
    fi
}

# ==============================================================================
# Formatting
# ==============================================================================

format_output() {
    local commits="$1"
    local summary="$2"
    local bullets="$3"
    local format="${ARG_FORMAT:-$DEFAULT_FORMAT}"
    local mode="${ARG_MODE:-$DEFAULT_MODE}"

    if [[ "$format" == "markdown" ]]; then
        format_markdown "$commits" "$summary" "$mode" "$bullets"
    else
        format_text "$commits" "$summary" "$mode" "$bullets"
    fi
}

format_markdown() {
    local commits="$1"
    local summary="$2"
    local mode="$3"
    local bullets="$4"

    echo "# Monthly Recap - ${REPO_NAME} - ${PERIOD_LABEL}"
    echo ""

    if [[ ("$mode" == "summary" || "$mode" == "all") && -n "$summary" ]]; then
        echo "## Summary"
        echo ""
        echo "$summary"
        echo ""
    fi

    if [[ "$mode" == "bullets" || "$mode" == "all" ]]; then
        if [[ -n "$bullets" ]]; then
            echo "## Changes"
            echo ""
            echo "$bullets" | while IFS= read -r line; do
                echo "- ${line}"
            done
            echo ""
        fi
    fi

    if [[ "$mode" == "commits" || "$mode" == "all" ]]; then
        if [[ -n "$commits" ]]; then
            echo "## Commits"
            echo ""
            echo "| Hash | Message | Date |"
            echo "|------|---------|------|"
            echo "$commits" | while IFS=$'\t' read -r hash msg date; do
                echo "| ${hash} | ${msg} | ${date} |"
            done
            echo ""
        fi
    fi
}

format_text() {
    local commits="$1"
    local summary="$2"
    local mode="$3"
    local bullets="$4"

    echo "=== Monthly Recap - ${REPO_NAME} - ${PERIOD_LABEL} ==="
    echo ""

    if [[ ("$mode" == "summary" || "$mode" == "all") && -n "$summary" ]]; then
        echo "--- Summary ---"
        echo ""
        echo "$summary"
        echo ""
    fi

    if [[ "$mode" == "bullets" || "$mode" == "all" ]]; then
        if [[ -n "$bullets" ]]; then
            echo "--- Changes ---"
            echo ""
            echo "$bullets" | while IFS= read -r line; do
                printf '  \u2022 %s\n' "$line"
            done
            echo ""
        fi
    fi

    if [[ "$mode" == "commits" || "$mode" == "all" ]]; then
        if [[ -n "$commits" ]]; then
            echo "--- Commits ---"
            echo ""
            echo "$commits" | while IFS=$'\t' read -r hash msg date; do
                echo "  ${hash} - ${msg} (${date})"
            done
            echo ""
        fi
    fi
}

# ==============================================================================
# Main
# ==============================================================================

main() {
    parse_args "$@"

    # Load config
    config_load

    # Handle --init
    if [[ "$ARG_INIT" == true ]]; then
        config_init
        exit 0
    fi

    validate_args

    # Resolve user: CLI flag > config > auto-detect
    if [[ -n "$ARG_USER" ]]; then
        USER_NAME="$ARG_USER"
    elif [[ -n "${GIT_RECAP_USER:-}" ]]; then
        USER_NAME="$GIT_RECAP_USER"
    else
        USER_NAME=$(detect_github_user)
        [[ -n "$USER_NAME" ]] || die "Could not detect GitHub user. Use -u or run --init"
    fi
    info "User: $USER_NAME"

    # Resolve provider
    if [[ -n "$ARG_PROVIDER" ]]; then
        PROVIDER="$ARG_PROVIDER"
    elif [[ -n "${GIT_RECAP_PROVIDER:-}" ]]; then
        PROVIDER="$GIT_RECAP_PROVIDER"
    else
        PROVIDER="$DEFAULT_PROVIDER"
    fi

    # Resolve format from config if not set via CLI
    if [[ -z "$ARG_FORMAT" && -n "${GIT_RECAP_FORMAT:-}" ]]; then
        ARG_FORMAT="$GIT_RECAP_FORMAT"
    fi

    # Resolve repo
    resolve_repo

    # Check deps
    check_dependencies

    # Detect branch
    detect_default_branch

    # Compute period
    compute_period

    # Fetch commits
    local commits
    commits=$(fetch_commits)

    if [[ -z "$commits" ]]; then
        local format="${ARG_FORMAT:-$DEFAULT_FORMAT}"
        local output=""
        if [[ "$format" == "markdown" ]]; then
            output="# Monthly Recap - ${REPO_NAME} - ${PERIOD_LABEL}

No commits found for **${USER_NAME}** during this period.
"
        else
            output="=== Monthly Recap - ${REPO_NAME} - ${PERIOD_LABEL} ===

No commits found for ${USER_NAME} during this period.
"
        fi
        if [[ -n "$ARG_OUTPUT" ]]; then
            echo "$output" > "$ARG_OUTPUT"
            info "Output written to $ARG_OUTPUT"
        else
            echo "$output"
        fi
        exit 0
    fi

    # Generate summary
    local summary=""
    summary=$(generate_summary "$commits")

    # Generate bullets
    local bullets=""
    bullets=$(generate_ai_bullets "$commits")

    # Format output
    local output
    output=$(format_output "$commits" "$summary" "$bullets")

    # Write or print
    if [[ -n "$ARG_OUTPUT" ]]; then
        echo "$output" > "$ARG_OUTPUT"
        info "Output written to $ARG_OUTPUT"
    else
        echo "$output"
    fi
}

main "$@"
