            echo "| Date | Hash | Message |"
            echo "|------|------|---------|"
            echo "$commits" | while IFS=$'\t' read -r hash msg date; do
                echo "| ${date} | [${hash}](https://github.com/${REPO_FULL}/commit/${hash}) | ${msg} |"
            done
            echo ""
        fi
