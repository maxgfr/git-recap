        echo ""
    fi

    if [[ ("$mode" == "summary" || "$mode" == "all") && -n "$summary" ]]; then
        echo "## Summary"
        echo ""
        echo "$summary"
        echo ""
    fi

    if [[ "$mode" == "bullets" || "$mode" == "all" ]]; then
        if [[ -n "$bullets" ]]; then
            echo "## Changes"
            echo ""
            echo "$bullets" | while IFS= read -r line; do
                [[ -n "$line" ]] && echo "- ${line}"
            done
            echo ""
        fi
    fi

    if [[ "$mode" == "commits" || "$mode" == "all" ]]; then
