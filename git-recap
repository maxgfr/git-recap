            ac_summary=$(generate_summary "$ac")
            ac_bullets=$(generate_ai_bullets "$ac")
        fi

        local contributor_json
        contributor_json=$(jq -n \
            --arg user "$author" \
            --argjson total "${a_total:-0}" \
            --argjson active_days "${a_active_days:-0}" \
            --argjson avg_per_day "${a_avg:-0.0}" \
            --argjson longest_streak "${a_streak:-0}" \
            --arg first_date "${a_first:-}" \
            --arg last_date "${a_last:-}" \
            --arg busiest_day "${a_busiest_day:-}" \
            --argjson busiest_count "${a_busiest_count:-0}" \
            --arg busiest_weekday "${a_weekday:-}" \
            '{
                user: $user,
                stats: {
                    total_commits: $total,
                    active_days: $active_days,
                    avg_per_day: $avg_per_day,
                    longest_streak: $longest_streak,
                    first_date: $first_date,
                    last_date: $last_date,
                    busiest_day: $busiest_day,
                    busiest_day_commits: $busiest_count,
                    busiest_weekday: $busiest_weekday
                }
            }')

        if [[ ("$mode" == "summary" || "$mode" == "all") && -n "$ac_summary" ]]; then
            contributor_json=$(echo "$contributor_json" | jq --arg s "$ac_summary" '. + {summary: $s}')
        fi

        if [[ ("$mode" == "bullets" || "$mode" == "all") && -n "$ac_bullets" ]]; then
            local bullets_arr
            bullets_arr=$(echo "$ac_bullets" | jq -R -s 'split("\n") | map(select(length > 0))')
            contributor_json=$(echo "$contributor_json" | jq --argjson b "$bullets_arr" '. + {bullets: $b}')
        fi

        if [[ ("$mode" == "commits" || "$mode" == "all") && -n "$ac" ]]; then
            local commits_arr
            commits_arr=$(echo "$ac" | jq -R -s '
                split("\n") | map(select(length > 0)) | map(
                    split("\t") | {hash: .[0], message: .[1], date: .[2]}
                )')
            contributor_json=$(echo "$contributor_json" | jq --argjson c "$commits_arr" '. + {commits: $c}')
        fi

        json=$(echo "$json" | jq --argjson c "$contributor_json" '.contributors += [$c]')
    done <<< "$authors"

    echo "$json"
}

output_team() {
    local all_commits="$1"
    local format="${ARG_FORMAT:-$DEFAULT_FORMAT}"

    case "$format" in
        text)     output_team_text "$all_commits" ;;
        markdown) output_team_markdown "$all_commits" ;;
        json)     output_team_json "$all_commits" ;;
    esac
}

# ==============================================================================
# Main
# ==============================================================================

main() {
    parse_args "$@"

    # Load config
    config_load

    # Handle --init
    if [[ "$ARG_INIT" == true ]]; then
        config_init
        exit 0
    fi

    validate_args

    # Resolve user: CLI flag > config > auto-detect
    if [[ "$ARG_TEAM" == true ]]; then
        # In team mode, user is optional (only needed for repo name resolution)
        if [[ -n "$ARG_USER" ]]; then
            USER_NAME="$ARG_USER"
        elif [[ -n "${GIT_RECAP_USER:-}" ]]; then
            USER_NAME="$GIT_RECAP_USER"
        else
            USER_NAME=$(detect_github_user) || true
        fi
        info "Team mode: all contributors"
    else
        if [[ -n "$ARG_USER" ]]; then
            USER_NAME="$ARG_USER"
        elif [[ -n "${GIT_RECAP_USER:-}" ]]; then
            USER_NAME="$GIT_RECAP_USER"
        else
            USER_NAME=$(detect_github_user)
            [[ -n "$USER_NAME" ]] || die "Could not detect GitHub user. Use -u or run --init"
        fi
        info "User: $USER_NAME"
    fi

    # Resolve provider
    if [[ -n "$ARG_PROVIDER" ]]; then
        PROVIDER="$ARG_PROVIDER"
    elif [[ -n "${GIT_RECAP_PROVIDER:-}" ]]; then
        PROVIDER="$GIT_RECAP_PROVIDER"
    else
        PROVIDER="$DEFAULT_PROVIDER"
    fi

    # Resolve model: CLI flag > config > empty (provider default)
    if [[ -n "$ARG_MODEL" ]]; then
        MODEL="$ARG_MODEL"
    elif [[ -n "${GIT_RECAP_MODEL:-}" ]]; then
        MODEL="$GIT_RECAP_MODEL"
    else
        MODEL=""
    fi

    # Resolve format from config if not set via CLI
    if [[ -z "$ARG_FORMAT" && -n "${GIT_RECAP_FORMAT:-}" ]]; then
        ARG_FORMAT="$GIT_RECAP_FORMAT"
    fi

    # Resolve language
    if [[ -n "$ARG_LANG" ]]; then
        LANG_CODE="$ARG_LANG"
    elif [[ -n "${GIT_RECAP_LANG:-}" ]]; then
        LANG_CODE="$GIT_RECAP_LANG"
    else
        LANG_CODE="$DEFAULT_LANG"
    fi

    # Resolve voice: normalize je→I, nous→we
    if [[ -n "$ARG_VOICE" ]]; then
        VOICE_MODE="$ARG_VOICE"
    elif [[ -n "${GIT_RECAP_VOICE:-}" ]]; then
        VOICE_MODE="$GIT_RECAP_VOICE"
    else
        VOICE_MODE="$DEFAULT_VOICE"
    fi
    case "$VOICE_MODE" in
        je|i) VOICE_MODE="I" ;;
        nous|We) VOICE_MODE="we" ;;
        neutre) VOICE_MODE="nominal" ;;
    esac

    # Default voice to neutral/nominal in team mode (unless user explicitly set a voice)
    if [[ "$ARG_TEAM" == true && -z "$ARG_VOICE" && -z "${GIT_RECAP_VOICE:-}" ]]; then
        if [[ "$LANG_CODE" == "fr" ]]; then
            VOICE_MODE="nominal"
        else
            VOICE_MODE="neutral"
        fi
    fi

    # Resolve repo
    resolve_repo

    # Check deps
    check_dependencies

    # Detect branch
    detect_default_branch

    # Compute period
    compute_period

    # === Team mode ===
    if [[ "$ARG_TEAM" == true ]]; then
        local all_commits
        all_commits=$(fetch_team_commits)

        if [[ -z "$all_commits" ]]; then
            local format="${ARG_FORMAT:-$DEFAULT_FORMAT}"
            local output=""
            case "$format" in
                markdown) output="# Team Recap - ${REPO_NAME} - ${PERIOD_LABEL}

No commits found during this period.
" ;;
                json) output=$(jq -n \
                    --arg repo "$REPO_FULL" \
                    --arg repo_name "$REPO_NAME" \
                    --arg period "$PERIOD_LABEL" \
                    --arg since "$SINCE" \
                    --arg until "$UNTIL" \
                    '{repo: $repo, repo_name: $repo_name, period: $period, since: $since, until: $until, team: true, contributors: []}') ;;
                *) output="=== Team Recap - ${REPO_NAME} - ${PERIOD_LABEL} ===

No commits found during this period.
" ;;
            esac
            if [[ -n "$ARG_OUTPUT" ]]; then
                echo "$output" > "$ARG_OUTPUT"
                info "Output written to $ARG_OUTPUT"
            else
                echo "$output"
            fi
            exit 0
        fi

        local output
        output=$(output_team "$all_commits")

        if [[ -n "$ARG_OUTPUT" ]]; then
            echo "$output" > "$ARG_OUTPUT"
            info "Output written to $ARG_OUTPUT"
        else
            echo "$output"
        fi
        exit 0
    fi

    # === Single user mode ===
    local commits
    commits=$(fetch_commits)

    if [[ -z "$commits" ]]; then
        local format="${ARG_FORMAT:-$DEFAULT_FORMAT}"
        local output=""
        case "$format" in
            markdown)
                output="# Monthly Recap - ${REPO_NAME} - ${PERIOD_LABEL}

No commits found for **${USER_NAME}** during this period.
"
                ;;
            json)
                output=$(jq -n \
                    --arg repo "$REPO_FULL" \
                    --arg repo_name "$REPO_NAME" \
                    --arg period "$PERIOD_LABEL" \
                    --arg since "$SINCE" \
                    --arg until "$UNTIL" \
                    --arg user "$USER_NAME" \
                    '{repo: $repo, repo_name: $repo_name, period: $period, since: $since, until: $until, user: $user, commits: []}')
                ;;
            *)
                output="=== Monthly Recap - ${REPO_NAME} - ${PERIOD_LABEL} ===

No commits found for ${USER_NAME} during this period.
"
                ;;
        esac
        if [[ -n "$ARG_OUTPUT" ]]; then
            echo "$output" > "$ARG_OUTPUT"
            info "Output written to $ARG_OUTPUT"
        else
            echo "$output"
        fi
        exit 0
    fi

    # Compute stats
    local stats
    stats=$(compute_stats "$commits")

    # Generate AI content
    local summary="" bullets=""
    local mode="${ARG_MODE:-$DEFAULT_MODE}"

    if [[ "$mode" == "all" && -n "$commits" ]]; then
        AI_SUMMARY=""
        AI_BULLETS=""
        if generate_ai_combined "$commits"; then
            summary="$AI_SUMMARY"
            bullets="$AI_BULLETS"
        else
            summary=$(generate_summary "$commits")
            bullets=$(generate_ai_bullets "$commits")
        fi
    else
        summary=$(generate_summary "$commits")
        bullets=$(generate_ai_bullets "$commits")
    fi

    # Format output
    local output
    output=$(format_output "$commits" "$summary" "$bullets" "$stats")

    # Write or print
    if [[ -n "$ARG_OUTPUT" ]]; then
        echo "$output" > "$ARG_OUTPUT"
        info "Output written to $ARG_OUTPUT"
    else
        echo "$output"
    fi
}

main "$@"
