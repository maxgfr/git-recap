# ==============================================================================
# Argument parsing
# ==============================================================================

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -u|--user)    ARG_USER="${2:?Missing value for $1}"; shift 2 ;;
            -p|--period)  ARG_PERIOD="${2:?Missing value for $1}"; shift 2 ;;
            -m|--mode)    ARG_MODE="${2:?Missing value for $1}"; shift 2 ;;
            -f|--format)  ARG_FORMAT="${2:?Missing value for $1}"; shift 2 ;;
            -o|--output)  ARG_OUTPUT="${2:?Missing value for $1}"; shift 2 ;;
            -b|--branch)  ARG_BRANCH="${2:?Missing value for $1}"; shift 2 ;;
            --provider)   ARG_PROVIDER="${2:?Missing value for $1}"; shift 2 ;;
            --model)      ARG_MODEL="${2:?Missing value for $1}"; shift 2 ;;
            --no-ai)      NO_AI=true; shift ;;
            --init)       ARG_INIT=true; shift ;;
            -h|--help)    show_help; exit 0 ;;
            -v|--version) echo "git-recap $VERSION"; exit 0 ;;
            -*)           die "Unknown option: $1" ;;
            *)
                [[ -z "$ARG_REPO" ]] || die "Unexpected argument: $1"
                ARG_REPO="$1"; shift ;;
        esac
    done
}

validate_args() {
    local mode="${ARG_MODE:-$DEFAULT_MODE}"
    local format="${ARG_FORMAT:-$DEFAULT_FORMAT}"
    local provider="${ARG_PROVIDER:-$DEFAULT_PROVIDER}"

    case "$mode" in
        summary|commits|bullets|all) ;;
        *) die "Invalid mode: $mode (expected: summary, commits, bullets, all)" ;;
    esac

    case "$format" in
        text|markdown|json) ;;
        *) die "Invalid format: $format (expected: text, markdown, json)" ;;
    esac

    case "$provider" in
        claude|claude-api|openai|mistral|gemini) ;;
        *) die "Invalid provider: $provider (expected: claude, claude-api, openai, mistral, gemini)" ;;
    esac

    if [[ "$ARG_INIT" == false && -z "$ARG_REPO" ]]; then
        die "Missing required argument: <repo>. Use -h for help."
    fi
}

# ==============================================================================
# Configuration
# ==============================================================================

config_load() {
    if [[ -f "$CONFIG_FILE" ]]; then
        local _line_num=0
        while IFS= read -r _line || [[ -n "$_line" ]]; do
            _line_num=$((_line_num + 1))
            [[ -z "$_line" || "$_line" =~ ^[[:space:]]*# ]] && continue
            if [[ "$_line" =~ ^GIT_RECAP_USER=\"([^\"]*)\"$ ]]; then
                GIT_RECAP_USER="${BASH_REMATCH[1]}"
            elif [[ "$_line" =~ ^GIT_RECAP_PROVIDER=\"([^\"]*)\"$ ]]; then
                GIT_RECAP_PROVIDER="${BASH_REMATCH[1]}"
            elif [[ "$_line" =~ ^GIT_RECAP_MODEL=\"([^\"]*)\"$ ]]; then
                GIT_RECAP_MODEL="${BASH_REMATCH[1]}"
            elif [[ "$_line" =~ ^GIT_RECAP_FORMAT=\"([^\"]*)\"$ ]]; then
                GIT_RECAP_FORMAT="${BASH_REMATCH[1]}"
            else
                warn "Ignoring unrecognized config line $_line_num in $CONFIG_FILE"
            fi
        done < "$CONFIG_FILE"
    fi
}

detect_github_user() {
    if command -v gh &>/dev/null; then
        if ! gh auth status &>/dev/null; then
            return
        fi
        gh api user --jq '.login' 2>/dev/null || true
    fi
}

config_init() {
    info "Initializing git-recap configuration..."

    local detected_user
    detected_user=$(detect_github_user)

    local user=""
    if [[ -n "$detected_user" ]]; then
        printf "GitHub username [%s]: " "$detected_user" >&2
        read -r user
        [[ -z "$user" ]] && user="$detected_user"
    else
        printf "GitHub username: " >&2
        read -r user
        [[ -z "$user" ]] && die "Username is required"
    fi

    local provider=""
    printf "AI provider (claude/claude-api/openai/mistral/gemini) [claude]: " >&2
    read -r provider
    [[ -z "$provider" ]] && provider="claude"

    local ai_model=""
    printf "AI model (leave empty for provider default): " >&2
    read -r ai_model

    local default_format=""
    printf "Default format (text/markdown/json) [text]: " >&2
    read -r default_format
    [[ -z "$default_format" ]] && default_format="text"

    cat > "$CONFIG_FILE" <<EOF
# git-recap configuration
GIT_RECAP_USER="$user"
GIT_RECAP_PROVIDER="$provider"
GIT_RECAP_MODEL="$ai_model"
GIT_RECAP_FORMAT="$default_format"
EOF

    info "Configuration saved to $CONFIG_FILE"
}

# ==============================================================================
# Period computation
# ==============================================================================

compute_period() {
    local period="${ARG_PERIOD:-$DEFAULT_PERIOD}"

    case "$period" in
        current|"")
            SINCE=$(portable_date first_of_month 0)
            UNTIL=$(portable_date first_of_next_month)
            PERIOD_LABEL=$(portable_date month_label 0)
            ;;
        last)
            SINCE=$(portable_date first_of_month -1)
            UNTIL=$(portable_date first_of_month 0)
            PERIOD_LABEL=$(portable_date month_label -1)
            ;;
        [0-9]|[0-9][0-9])
            local n="$period"
            SINCE=$(portable_date first_of_month "-${n}")
            UNTIL=$(portable_date first_of_next_month)
            local start_label end_label
            start_label=$(portable_date month_label "-${n}")
            end_label=$(portable_date month_label 0)
            PERIOD_LABEL="${start_label} - ${end_label}"
            ;;
        [0-9][0-9][0-9][0-9]-[0-9][0-9])
            local year="${period%%-*}"
            local month="${period##*-}"
            SINCE="${year}-${month}-01T00:00:00"
            local next_month=$((10#$month + 1))
            local next_year="$year"
            if [[ $next_month -gt 12 ]]; then
                next_month=1
                next_year=$((year + 1))
            fi
            UNTIL=$(printf '%s-%02d-01T00:00:00' "$next_year" "$next_month")
            PERIOD_LABEL=$(portable_date month_label_from "${year}-${month}-01")
            ;;
        *)
            die "Invalid period: $period (expected: current, last, <N>, YYYY-MM)"
            ;;
    esac

    info "Period: $PERIOD_LABEL ($SINCE → $UNTIL)"
}

# ==============================================================================
# Repo resolution
# ==============================================================================

resolve_repo() {
    local repo="$ARG_REPO"

    # Local path
    if [[ "$repo" == "." || "$repo" == "./" || -d "$repo/.git" ]]; then
        REPO_MODE="local"
        local dir
        if [[ "$repo" == "." || "$repo" == "./" ]]; then
            dir="$(pwd)"
        else
            dir="$(cd "$repo" && pwd)"
        fi
        local remote_url
        remote_url=$(git -C "$dir" remote get-url origin 2>/dev/null) || die "No remote 'origin' found in $dir"
        REPO_FULL=$(echo "$remote_url" | sed -E 's#^(https://github\.com/|git@github\.com:)##; s/\.git$//')
        REPO_NAME="${REPO_FULL##*/}"
        info "Local repo: $REPO_FULL"
        return
    fi

    REPO_MODE="remote"

    # GitHub URL
    if [[ "$repo" == https://github.com/* ]]; then
        REPO_FULL=$(echo "$repo" | sed -E 's#^https://github\.com/##; s/\.git$//; s#/$##')
        REPO_NAME="${REPO_FULL##*/}"
        info "Repo: $REPO_FULL"
        return
    fi

    # SSH URL
    if [[ "$repo" == git@github.com:* ]]; then
        REPO_FULL=$(echo "$repo" | sed -E 's#^git@github\.com:##; s/\.git$//')
        REPO_NAME="${REPO_FULL##*/}"
        info "Repo: $REPO_FULL"
        return
    fi

    # owner/repo
    if [[ "$repo" == */* ]]; then
        REPO_FULL="$repo"
        REPO_NAME="${REPO_FULL##*/}"
        info "Repo: $REPO_FULL"
        return
    fi

    # repo name only — prefix with username
    REPO_FULL="${USER_NAME}/${repo}"
    REPO_NAME="$repo"
    info "Repo: $REPO_FULL (using user: $USER_NAME)"
}

detect_default_branch() {
    if [[ -n "$ARG_BRANCH" ]]; then
        BRANCH="$ARG_BRANCH"
        return
    fi

    if [[ "$REPO_MODE" == "local" ]]; then
        BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's#refs/remotes/origin/##' || echo "main")
    else
        BRANCH=$(gh api "repos/${REPO_FULL}" --jq '.default_branch' 2>/dev/null || echo "main")
    fi

    info "Branch: $BRANCH"
}

# ==============================================================================
# Dependencies
# ==============================================================================

check_gh_auth() {
    if command -v gh &>/dev/null; then
        if ! gh auth status &>/dev/null; then
            die "gh is not authenticated. Run: gh auth login"
        fi
    fi
}

check_dependencies() {
    command -v git &>/dev/null || die "git is required but not found"

    local format="${ARG_FORMAT:-$DEFAULT_FORMAT}"
    if [[ "$format" == "json" ]]; then
        command -v jq &>/dev/null || die "jq is required for JSON format"
    fi

    if [[ "${REPO_MODE:-remote}" == "remote" ]]; then
        if ! command -v gh &>/dev/null && ! command -v curl &>/dev/null; then
            die "gh or curl is required for remote repos"
        fi
        check_gh_auth
    fi

    if [[ "$NO_AI" == false ]]; then
        local mode="${ARG_MODE:-$DEFAULT_MODE}"
        if [[ "$mode" == "summary" || "$mode" == "bullets" || "$mode" == "all" ]]; then
            case "$PROVIDER" in
                claude)
                    command -v claude &>/dev/null || warn "claude CLI not found — AI will be skipped"
                    ;;
                claude-api)
                    [[ -n "${ANTHROPIC_API_KEY:-}" ]] || warn "ANTHROPIC_API_KEY not set — AI will be skipped"
                    ;;
                openai)
                    [[ -n "${OPENAI_API_KEY:-}" ]] || warn "OPENAI_API_KEY not set — AI will be skipped"
                    ;;
                mistral)
                    [[ -n "${MISTRAL_API_KEY:-}" ]] || warn "MISTRAL_API_KEY not set — AI will be skipped"
                    ;;
                gemini)
                    [[ -n "${GEMINI_API_KEY:-}" ]] || warn "GEMINI_API_KEY not set — AI will be skipped"
                    ;;
            esac
        fi
    fi
}

# ==============================================================================
# Fetch commits
# ==============================================================================

fetch_commits() {
    local commits=""

    if [[ "$REPO_MODE" == "local" ]]; then
        info "Fetching commits (local)..."
        local dir="$ARG_REPO"
        [[ "$dir" == "." || "$dir" == "./" ]] && dir="$(pwd)"
        commits=$(git -C "$dir" log "$BRANCH" \
            --author="$USER_NAME" \
            --since="$SINCE" --until="$UNTIL" \
            --format='%h%x09%s%x09%as' --no-merges 2>/dev/null || true)
    elif command -v gh &>/dev/null; then
        info "Fetching commits (gh api)..."
        local api_url="repos/${REPO_FULL}/commits?sha=${BRANCH}&author=${USER_NAME}&since=${SINCE}Z&until=${UNTIL}Z&per_page=100"
        local api_err=""
        commits=$(gh api "$api_url" --paginate \
            --jq '.[] | [.sha[0:7], (.commit.message | split("\n")[0]), (.commit.author.date | split("T")[0])] | @tsv' 2>&1) || api_err="$commits"
        if [[ -n "$api_err" ]]; then
            case "$api_err" in
                *"404"*) die "Repository not found: ${REPO_FULL}" ;;
                *"403"*) die "Access denied (rate limit or permissions): ${REPO_FULL}" ;;
                *) die "API error: ${api_err}" ;;
            esac
        fi
    elif command -v curl &>/dev/null; then
        info "Fetching commits (curl)..."
        command -v jq &>/dev/null || die "jq is required when using curl fallback"
        local url="https://api.github.com/repos/${REPO_FULL}/commits?sha=${BRANCH}&author=${USER_NAME}&since=${SINCE}Z&until=${UNTIL}Z&per_page=100"
        local tmpheaders
        tmpheaders=$(mktemp)
        while [[ -n "$url" ]]; do
            local page_json
            page_json=$(curl -s -D "$tmpheaders" "$url")
            local page_commits
            page_commits=$(echo "$page_json" | jq -r '.[] | [.sha[0:7], (.commit.message | split("\n")[0]), (.commit.author.date | split("T")[0])] | @tsv' 2>/dev/null || true)
            if [[ -n "$page_commits" ]]; then
                if [[ -n "$commits" ]]; then
                    commits="${commits}"$'\n'"${page_commits}"
                else
                    commits="$page_commits"
                fi
            fi
            # Parse Link header for next page
            local next_url
            next_url=$(sed -n 's/.*<\([^>]*\)>; *rel="next".*/\1/p' "$tmpheaders" | tr -d '\r') || true
            url="$next_url"
        done
        rm -f "$tmpheaders"
    else
        die "No method available to fetch commits"
    fi

    if [[ -z "$commits" ]]; then
        warn "No commits found for $USER_NAME on $REPO_FULL ($PERIOD_LABEL)"
        echo ""
        return
    fi

    local count
    count=$(echo "$commits" | wc -l | tr -d ' ')
    info "Found $count commit(s)"

    echo "$commits"
}

# ==============================================================================
# AI
# ==============================================================================

# OpenAI-compatible API call (works for openai + mistral)
_call_openai_compatible() {
    local url="$1" api_key="$2" model="$3" prompt="$4"
    local escaped_prompt
    escaped_prompt=$(printf '%s' "$prompt" | _json_escape)
    local response
    response=$(curl -s "$url" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $api_key" \
        -d "{\"model\":\"${model}\",\"messages\":[{\"role\":\"user\",\"content\":${escaped_prompt}}],\"temperature\":0.7}") || true
    if command -v jq &>/dev/null; then
        echo "$response" | jq -r '.choices[0].message.content // empty' 2>/dev/null || true
    fi
}

# Anthropic Messages API call
_call_anthropic() {
    local api_key="$1" model="$2" prompt="$3"
    local escaped_prompt
    escaped_prompt=$(printf '%s' "$prompt" | _json_escape)
    local response
    response=$(curl -s "https://api.anthropic.com/v1/messages" \
        -H "Content-Type: application/json" \
        -H "x-api-key: $api_key" \
        -H "anthropic-version: 2023-06-01" \
        -d "{\"model\":\"${model}\",\"max_tokens\":4096,\"messages\":[{\"role\":\"user\",\"content\":${escaped_prompt}}]}") || true
    if command -v jq &>/dev/null; then
        echo "$response" | jq -r '.content[0].text // empty' 2>/dev/null || true
    fi
}

# Gemini API call
_call_gemini() {
    local api_key="$1" model="$2" prompt="$3"
    local escaped_prompt
    escaped_prompt=$(printf '%s' "$prompt" | _json_escape)
    local response
    response=$(curl -s "https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${api_key}" \
        -H "Content-Type: application/json" \
        -d "{\"contents\":[{\"parts\":[{\"text\":${escaped_prompt}}]}],\"generationConfig\":{\"temperature\":0.7}}") || true
    if command -v jq &>/dev/null; then
        echo "$response" | jq -r '.candidates[0].content.parts[0].text // empty' 2>/dev/null || true
    fi
}

# call_ai <prompt> <spinner_msg> → stdout, returns 0 on success
call_ai() {
    local prompt="$1"
    local spinner_msg="$2"

    if [[ "$NO_AI" == true ]]; then
        return 1
    fi

    local result=""
    local model="$MODEL"

    case "$PROVIDER" in
        claude)
            if ! command -v claude &>/dev/null; then
                warn "claude CLI not found — skipping AI"
                return 1
            fi
            [[ -z "$model" ]] && model="haiku"
            spinner_start "$spinner_msg"
            result=$(unset CLAUDECODE; printf '%s' "$prompt" | claude -p --model "$model" 2>/dev/null) || true
            spinner_stop
            ;;
        openai)
            if [[ -z "${OPENAI_API_KEY:-}" ]]; then
                warn "OPENAI_API_KEY not set — skipping AI"
                return 1
            fi
            [[ -z "$model" ]] && model="gpt-4o-mini"
            spinner_start "$spinner_msg"
            result=$(_call_openai_compatible \
                "https://api.openai.com/v1/chat/completions" \
                "$OPENAI_API_KEY" "$model" "$prompt") || true
            spinner_stop
            ;;
        mistral)
            if [[ -z "${MISTRAL_API_KEY:-}" ]]; then
                warn "MISTRAL_API_KEY not set — skipping AI"
                return 1
            fi
            [[ -z "$model" ]] && model="mistral-small-latest"
            spinner_start "$spinner_msg"
            result=$(_call_openai_compatible \
                "https://api.mistral.ai/v1/chat/completions" \
                "$MISTRAL_API_KEY" "$model" "$prompt") || true
            spinner_stop
            ;;
        gemini)
            if [[ -z "${GEMINI_API_KEY:-}" ]]; then
                warn "GEMINI_API_KEY not set — skipping AI"
                return 1
            fi
            [[ -z "$model" ]] && model="gemini-2.0-flash"
            spinner_start "$spinner_msg"
            result=$(_call_gemini "$GEMINI_API_KEY" "$model" "$prompt") || true
            spinner_stop
            ;;
        claude-api)
            if [[ -z "${ANTHROPIC_API_KEY:-}" ]]; then
                warn "ANTHROPIC_API_KEY not set — skipping AI"
                return 1
            fi
            [[ -z "$model" ]] && model="claude-haiku-4-5-20251001"
            spinner_start "$spinner_msg"
            result=$(_call_anthropic "$ANTHROPIC_API_KEY" "$model" "$prompt") || true
            spinner_stop
            ;;
    esac

    if [[ -n "$result" ]]; then
        echo "$result"
        return 0
    fi
    return 1
}

generate_summary() {
    local commits="$1"
    local mode="${ARG_MODE:-$DEFAULT_MODE}"

    [[ "$mode" != "summary" && "$mode" != "all" ]] && return
    [[ -z "$commits" ]] && return

    local messages
    messages=$(echo "$commits" | cut -f2 | _truncate_messages 200)

    local prompt
    prompt="You are writing a professional monthly work recap. Below are git commit messages from a developer for ${PERIOD_LABEL} on the repository ${REPO_NAME}.

Write a concise summary (3-5 sentences) suitable for a monthly report. Synthesize by themes (features, bug fixes, refactoring, documentation, etc.). Use a professional tone. Do not list individual commits — provide a high-level overview of what was accomplished.

Commit messages:
${messages}"

    local summary
    if summary=$(call_ai "$prompt" "Generating AI summary..."); then
        echo "$summary"
    else
        warn "AI summary generation failed — skipping"
    fi
}

generate_ai_bullets() {
    local commits="$1"
    local mode="${ARG_MODE:-$DEFAULT_MODE}"

    [[ "$mode" != "bullets" && "$mode" != "all" ]] && return
    [[ -z "$commits" ]] && return

    local messages
    messages=$(echo "$commits" | cut -f2 | _truncate_messages 200)

    local prompt
    prompt="You are writing bullet points for a monthly work recap. Below are git commit messages from a developer for ${PERIOD_LABEL} on the repository ${REPO_NAME}.

Transform these commit messages into clean, readable bullet points for a report:
- Group related changes by theme
- Deduplicate similar entries
- Rephrase in clear, professional language
- Remove conventional commit prefixes (feat:, fix:, chore:, etc.)
- Output one bullet point per line, without any bullet marker (no -, *, etc.)
- Do not include any headers or categories — just the items

Commit messages:
${messages}"

    local bullets
    if bullets=$(call_ai "$prompt" "Generating AI bullet points..."); then
        echo "$bullets" | _strip_bullet_markers
    else
        # Fallback: raw commit messages
        echo "$messages"
    fi
}

# Single AI call for mode=all (summary + bullets in one request)
# Sets AI_SUMMARY and AI_BULLETS globals, returns 0 on success
generate_ai_combined() {
    local commits="$1"
    [[ -z "$commits" ]] && return 1

    local messages
    messages=$(echo "$commits" | cut -f2 | _truncate_messages 200)

    local prompt
    prompt="You are writing a professional monthly work recap. Below are git commit messages from a developer for ${PERIOD_LABEL} on the repository ${REPO_NAME}.

PART 1 - SUMMARY:
Write a concise summary (3-5 sentences) suitable for a monthly report. Synthesize by themes (features, bug fixes, refactoring, documentation, etc.). Use a professional tone. Do not list individual commits — provide a high-level overview.

After the summary, output exactly this separator on its own line:
---SPLIT---

PART 2 - BULLET POINTS:
Transform the commit messages into clean, readable bullet points:
- Group related changes by theme
- Deduplicate similar entries
- Rephrase in clear, professional language
- Remove conventional commit prefixes (feat:, fix:, chore:, etc.)
- Output one bullet point per line, without any bullet marker (no -, *, etc.)
- Do not include any headers or categories — just the items

Commit messages:
${messages}"

    local result
    if result=$(call_ai "$prompt" "Generating AI recap..."); then
        if [[ "$result" == *"---SPLIT---"* ]]; then
            AI_SUMMARY=$(echo "$result" | sed -n '1,/---SPLIT---/{/---SPLIT---/!p}')
            AI_BULLETS=$(echo "$result" | sed '1,/---SPLIT---/d' | _strip_bullet_markers)
            if [[ -n "$AI_SUMMARY" && -n "$AI_BULLETS" ]]; then
                return 0
            fi
        fi
    fi
    return 1
}

# ==============================================================================
# Stats
# ==============================================================================

compute_stats() {
    local commits="$1"
    [[ -z "$commits" ]] && return

    local total
    total=$(echo "$commits" | wc -l | tr -d ' ')

    local dates
    dates=$(echo "$commits" | cut -f3 | sort)
    local first_date last_date
    first_date=$(echo "$dates" | head -1)
    last_date=$(echo "$dates" | tail -1)

    # Most active day
    local busiest_line
    busiest_line=$(echo "$dates" | sort | uniq -c | sort -rn | head -1)
    local busiest_count busiest_day
    busiest_count=$(echo "$busiest_line" | awk '{print $1}')
    busiest_day=$(echo "$busiest_line" | awk '{print $2}')

    printf '%s|%s|%s|%s|%s' "$total" "$first_date" "$last_date" "$busiest_day" "$busiest_count"
}

# ==============================================================================
# Formatting
# ==============================================================================

format_output() {
    local commits="$1"
    local summary="$2"
    local bullets="$3"
    local stats="$4"
    local format="${ARG_FORMAT:-$DEFAULT_FORMAT}"
    local mode="${ARG_MODE:-$DEFAULT_MODE}"

    case "$format" in
        markdown) format_markdown "$commits" "$summary" "$mode" "$bullets" "$stats" ;;
        json)     format_json "$commits" "$summary" "$mode" "$bullets" "$stats" ;;
        *)        format_text "$commits" "$summary" "$mode" "$bullets" "$stats" ;;
    esac
}

format_markdown() {
    local commits="$1"
    local summary="$2"
    local mode="$3"
    local bullets="$4"
    local stats="$5"

    echo "# Monthly Recap - ${REPO_NAME} - ${PERIOD_LABEL}"
    echo ""

    if [[ -n "$stats" ]]; then
        local total first_date last_date busiest_day busiest_count
        IFS='|' read -r total first_date last_date busiest_day busiest_count <<< "$stats"
        echo "## Stats"
        echo ""
        echo "| Metric | Value |"
        echo "|--------|-------|"
        echo "| Total commits | ${total} |"
        echo "| First commit | ${first_date} |"
        echo "| Last commit | ${last_date} |"
        echo "| Busiest day | ${busiest_day} (${busiest_count} commits) |"
        echo ""
    fi

    if [[ ("$mode" == "summary" || "$mode" == "all") && -n "$summary" ]]; then
        echo "## Summary"
        echo ""
        echo "$summary"
        echo ""
    fi

    if [[ "$mode" == "bullets" || "$mode" == "all" ]]; then
        if [[ -n "$bullets" ]]; then
            echo "## Changes"
            echo ""
            echo "$bullets" | while IFS= read -r line; do
                [[ -n "$line" ]] && echo "- ${line}"
            done
            echo ""
        fi
    fi

    if [[ "$mode" == "commits" || "$mode" == "all" ]]; then
        if [[ -n "$commits" ]]; then
            echo "## Commits"
            echo ""
            echo "| Hash | Message | Date |"
            echo "|------|---------|------|"
            echo "$commits" | while IFS=$'\t' read -r hash msg date; do
                echo "| [${hash}](https://github.com/${REPO_FULL}/commit/${hash}) | ${msg} | ${date} |"
            done
            echo ""
        fi
    fi
}

format_text() {
    local commits="$1"
    local summary="$2"
    local mode="$3"
    local bullets="$4"
    local stats="$5"

    echo "=== Monthly Recap - ${REPO_NAME} - ${PERIOD_LABEL} ==="
    echo ""

    if [[ -n "$stats" ]]; then
        local total first_date last_date busiest_day busiest_count
        IFS='|' read -r total first_date last_date busiest_day busiest_count <<< "$stats"
        echo "--- Stats ---"
        echo ""
        echo "  Total commits: ${total}"
        echo "  First commit:  ${first_date}"
        echo "  Last commit:   ${last_date}"
        echo "  Busiest day:   ${busiest_day} (${busiest_count} commits)"
        echo ""
    fi

    if [[ ("$mode" == "summary" || "$mode" == "all") && -n "$summary" ]]; then
        echo "--- Summary ---"
        echo ""
        echo "$summary"
        echo ""
    fi

    if [[ "$mode" == "bullets" || "$mode" == "all" ]]; then
        if [[ -n "$bullets" ]]; then
            echo "--- Changes ---"
            echo ""
            echo "$bullets" | while IFS= read -r line; do
                [[ -n "$line" ]] && printf '  \u2022 %s\n' "$line"
            done
            echo ""
        fi
    fi

    if [[ "$mode" == "commits" || "$mode" == "all" ]]; then
        if [[ -n "$commits" ]]; then
            echo "--- Commits ---"
            echo ""
            echo "$commits" | while IFS=$'\t' read -r hash msg date; do
                echo "  ${hash} - ${msg} (${date})"
            done
            echo ""
        fi
    fi
}

format_json() {
    local commits="$1"
    local summary="$2"
    local mode="$3"
    local bullets="$4"
    local stats="$5"

    local total first_date last_date busiest_day busiest_count
    if [[ -n "$stats" ]]; then
        IFS='|' read -r total first_date last_date busiest_day busiest_count <<< "$stats"
    else
        total=0 first_date="" last_date="" busiest_day="" busiest_count=0
    fi

    local json
    json=$(jq -n \
        --arg repo "$REPO_FULL" \
        --arg repo_name "$REPO_NAME" \
        --arg period "$PERIOD_LABEL" \
        --arg since "$SINCE" \
        --arg until "$UNTIL" \
        --arg user "$USER_NAME" \
        --argjson total "${total:-0}" \
        --arg first_date "${first_date:-}" \
        --arg last_date "${last_date:-}" \
        --arg busiest_day "${busiest_day:-}" \
        --argjson busiest_count "${busiest_count:-0}" \
        '{
            repo: $repo,
            repo_name: $repo_name,
            period: $period,
            since: $since,
            until: $until,
            user: $user,
            stats: {
                total_commits: $total,
                first_date: $first_date,
                last_date: $last_date,
                busiest_day: $busiest_day,
                busiest_day_commits: $busiest_count
            }
        }')

    if [[ ("$mode" == "summary" || "$mode" == "all") && -n "$summary" ]]; then
        json=$(echo "$json" | jq --arg s "$summary" '. + {summary: $s}')
    fi

    if [[ ("$mode" == "bullets" || "$mode" == "all") && -n "$bullets" ]]; then
        local bullets_arr
        bullets_arr=$(echo "$bullets" | jq -R -s 'split("\n") | map(select(length > 0))')
        json=$(echo "$json" | jq --argjson b "$bullets_arr" '. + {bullets: $b}')
    fi

    if [[ ("$mode" == "commits" || "$mode" == "all") && -n "$commits" ]]; then
        local commits_arr
        commits_arr=$(echo "$commits" | jq -R -s '
            split("\n") | map(select(length > 0)) | map(
                split("\t") | {hash: .[0], message: .[1], date: .[2]}
            )')
        json=$(echo "$json" | jq --argjson c "$commits_arr" '. + {commits: $c}')
    fi

    echo "$json"
}

# ==============================================================================
# Main
# ==============================================================================

main() {
    parse_args "$@"

    # Load config
    config_load

    # Handle --init
    if [[ "$ARG_INIT" == true ]]; then
        config_init
        exit 0
    fi

    validate_args

    # Resolve user: CLI flag > config > auto-detect
    if [[ -n "$ARG_USER" ]]; then
        USER_NAME="$ARG_USER"
    elif [[ -n "${GIT_RECAP_USER:-}" ]]; then
        USER_NAME="$GIT_RECAP_USER"
    else
        USER_NAME=$(detect_github_user)
        [[ -n "$USER_NAME" ]] || die "Could not detect GitHub user. Use -u or run --init"
    fi
    info "User: $USER_NAME"

    # Resolve provider
    if [[ -n "$ARG_PROVIDER" ]]; then
        PROVIDER="$ARG_PROVIDER"
    elif [[ -n "${GIT_RECAP_PROVIDER:-}" ]]; then
        PROVIDER="$GIT_RECAP_PROVIDER"
    else
        PROVIDER="$DEFAULT_PROVIDER"
    fi

    # Resolve model: CLI flag > config > empty (provider default)
    if [[ -n "$ARG_MODEL" ]]; then
        MODEL="$ARG_MODEL"
    elif [[ -n "${GIT_RECAP_MODEL:-}" ]]; then
        MODEL="$GIT_RECAP_MODEL"
    else
        MODEL=""
    fi

    # Resolve format from config if not set via CLI
    if [[ -z "$ARG_FORMAT" && -n "${GIT_RECAP_FORMAT:-}" ]]; then
        ARG_FORMAT="$GIT_RECAP_FORMAT"
    fi

    # Resolve repo
    resolve_repo

    # Check deps
    check_dependencies

    # Detect branch
    detect_default_branch

    # Compute period
    compute_period

    # Fetch commits
    local commits
    commits=$(fetch_commits)

    if [[ -z "$commits" ]]; then
        local format="${ARG_FORMAT:-$DEFAULT_FORMAT}"
        local output=""
        case "$format" in
            markdown)
                output="# Monthly Recap - ${REPO_NAME} - ${PERIOD_LABEL}

No commits found for **${USER_NAME}** during this period.
"
                ;;
            json)
                output=$(jq -n \
                    --arg repo "$REPO_FULL" \
                    --arg repo_name "$REPO_NAME" \
                    --arg period "$PERIOD_LABEL" \
                    --arg since "$SINCE" \
                    --arg until "$UNTIL" \
                    --arg user "$USER_NAME" \
                    '{repo: $repo, repo_name: $repo_name, period: $period, since: $since, until: $until, user: $user, commits: []}')
                ;;
            *)
                output="=== Monthly Recap - ${REPO_NAME} - ${PERIOD_LABEL} ===

No commits found for ${USER_NAME} during this period.
"
                ;;
        esac
        if [[ -n "$ARG_OUTPUT" ]]; then
            echo "$output" > "$ARG_OUTPUT"
            info "Output written to $ARG_OUTPUT"
        else
            echo "$output"
        fi
        exit 0
    fi

    # Compute stats
    local stats
    stats=$(compute_stats "$commits")

    # Generate AI content
    local summary="" bullets=""
    local mode="${ARG_MODE:-$DEFAULT_MODE}"

    if [[ "$mode" == "all" && -n "$commits" ]]; then
        AI_SUMMARY=""
        AI_BULLETS=""
        if generate_ai_combined "$commits"; then
            summary="$AI_SUMMARY"
            bullets="$AI_BULLETS"
        else
            summary=$(generate_summary "$commits")
            bullets=$(generate_ai_bullets "$commits")
        fi
    else
        summary=$(generate_summary "$commits")
        bullets=$(generate_ai_bullets "$commits")
    fi

    # Format output
    local output
    output=$(format_output "$commits" "$summary" "$bullets" "$stats")

    # Write or print
    if [[ -n "$ARG_OUTPUT" ]]; then
        echo "$output" > "$ARG_OUTPUT"
        info "Output written to $ARG_OUTPUT"
    else
        echo "$output"
    fi
}

main "$@"
